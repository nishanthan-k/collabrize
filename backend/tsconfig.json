{
  "compilerOptions": {
    "target": "ES6",                   // Use ES6 as the JavaScript target
    "module": "commonjs",              // Use CommonJS for module resolution
    "moduleResolution": "node",        // Resolve modules in Node.js style
    "outDir": "./dist",                // Compile output directory
    "rootDir": "./",                   // Root directory includes index.ts and src
    "esModuleInterop": true,           // Allow default imports from CommonJS
    "skipLibCheck": true,              // Skip type checking in .d.ts files
    "strict": true,                    // Enable strict type checking
    "resolveJsonModule": true,         // Allow importing JSON files
    "baseUrl": "./",                   // Base directory for module imports
    "paths": {
      "@controllers/*": ["src/controllers/*"],
      "@routes/*": ["src/routes/*"],
      "@middlewares/*": ["src/middlewares/*"],
      "@utils/*": ["src/utils/*"],
      "@lib/*": ["src/lib/*"]
    }
  },
  "include": ["index.ts", "src/**/*.ts"], // Include root index.ts and all src files
  "exclude": ["node_modules", "dist"]    // Exclude node_modules and dist
}
